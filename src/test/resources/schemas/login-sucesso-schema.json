{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "Login Sucesso Response",
  "type": "object",
  "required": ["message", "data"],
  "properties": {
    "message": { "type": "string" },
    "error":   { "type": "string" },
    "data": {
      "type": "object",
      "required": ["token"],
      "properties": {
        "token": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
