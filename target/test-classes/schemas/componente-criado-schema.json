{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "Componente Criado Response",
  "type": "object",
  "required": ["message", "data"],
  "properties": {
    "message": { "type": "string" },
    "error":   { "type": "string" },
    "data": {
      "type": "object",
      "required": ["componenteId", "componenteNome", "componenteQuantidade"],
      "properties": {
        "componenteId": {
          "type": "integer",
          "minimum": 1
        },
        "componenteNome": {
          "type": "string",
          "minLength": 1
        },
        "componenteQuantidade": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
